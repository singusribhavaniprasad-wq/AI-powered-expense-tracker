# Vercel Production Environment Variables Configuration Template
# Set these inside Vercel Dashboard -> Project Settings -> Environment Variables

# Node runtime environment
NODE_ENV=production

# Your MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/expense-tracker?retryWrites=true&w=majority

# Your Google AI Studio Gemini API Key for OCR extraction
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Application Port redirection (optional, Vercel binds dynamically)
PORT=8080
